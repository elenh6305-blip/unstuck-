# ============================================================
# .env.example — 环境变量模板
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
# ============================================================

# ── 后端 AI 代理配置 ────────────────────────────────
# 后端使用的 AI 服务 API Key（DeepSeek、OpenAI 兼容格式）
BACKEND_AI_API_KEY=sk-xxxxxxxxxxxxxxxx

# AI 服务的 Base URL
# DeepSeek:     https://api.deepseek.com
# OpenAI:       https://api.openai.com
# Moonshot:     https://api.moonshot.cn
# 通义千问:     https://dashscope.aliyuncs.com/compatible-mode
BACKEND_AI_BASE_URL=https://api.deepseek.com

# 使用的模型名称
# DeepSeek:     deepseek-chat / deepseek-reasoner
# OpenAI:       gpt-4o / gpt-4o-mini
# Moonshot:     moonshot-v1-8k
# 通义千问:     qwen-plus
BACKEND_AI_MODEL=deepseek-chat

# ── 服务器配置（仅独立部署时需要）─────────────────────
# 后端服务监听端口
PORT=3001
